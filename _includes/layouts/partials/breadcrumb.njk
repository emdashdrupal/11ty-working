<div aria-label="breadcrumb" class="mx-auto rounded-b-md border-6 mb-4 px-4 bg-gray-200 max-w-4xl align-top shadow-md">
    <span class="fa-solid fa-house text-grey-green"></span><a href="/">Home</a>
    {%- if category -%}
        <span class="fa-solid fa-chevron-right mx-2 text-sm"></span>
        {%- if categoryFontAwesomeIcon -%}
            <span class="fa-{{ categoryFontAwesomeIcon }} mx-2 text-grey-green"></span>
        {%- endif -%}
        {# If the current page URL contains "blog", link to the blog category path. Otherwise use the top-level category path. #}
        {%- if page and page.url and '/blog/' in page.url -%}
            <a href="/blog">{{ category|trim }}</a>
        {%- else -%}
            <a href="/{{ category | slugify }}">{{ category|trim }}</a>
        {%- endif -%}
    {%- endif -%}
    <span class="fa-solid fa-chevron-right mx-2 text-sm"></span>
    <span class="text-gray-600" aria-current="page">
        {%- if FontAwesomeIcon -%}
            <span class="fa-{{ FontAwesomeIcon }} mx-2"></span>
        {% endif %}{{ title| trim }}</span>
</div>
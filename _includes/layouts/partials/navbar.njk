<div class="grid grid-cols-4 md:grid-cols-12 gap-4 max-w-4xl px-2">
    <div id="tagline" class="col-span-3 md:col-span-4">
        <a href="/" class="font-sans jet-200 font-semibold">
            Successful technical content through community building
        </a>
    </div>
    <button id="menuToggle" class="md:hidden col-span-1 justify-self-end" aria-expanded="false" aria-controls="menubar">
        <i class="fa-solid fa-bars text-2xl"></i>
        <span class="sr-only">Toggle menu</span>
    </button>
    <div id="menubar" class="hidden md:block col-span-4 md:col-span-8 mt-2 sm:float-right">
        <ul class="gap-2 items-start md:items-center md:justify-end"
            aria-label="Main navigation menu"
            role="menubar">
        <li class="hidden">{{ collections.all | eleventyNavigation | eleventyNavigationToHtml | safe }}</li>
         <li class="relative hover:jet-200">
                <button id="searchToggle" class="inline-flex items-center" aria-expanded="false" aria-controls="search">
                    <i class="fa-solid fa-search text-2xl"></i>
                    <span class="sr-only">Toggle search</span>
                </button>
                <div id="search" class="hidden absolute right-0 top-full mt-2 w-64 rounded-sm shadow-lg"></div>
            </li>
    </div>
    {% set navPages = collections.all | eleventyNavigation %}

<nav class="navbar" aria-label="Main Navigation">
  <ul class="nav-list">
    {%- for entry in navPages %}
      {% set hasChildren = entry.children | length > 0 %}
      <li class="nav-item{% if hasChildren %} has-dropdown{% endif %}">
        {% if hasChildren %}
          <button class="dropdown-toggle" aria-expanded="false" aria-haspopup="true">
            {{ entry.title }} <span class="arrow" aria-hidden="true">&#9660;</span>
          </button>
          <ul class="dropdown-menu">
            {%- for child in entry.children %}
              <li class="dropdown-item{% if child.children %} has-submenu{% endif %}">
                {% if child.children %}
                  <button class="dropdown-toggle" aria-expanded="false" aria-haspopup="true">
                    {{ child.title }}</span>
                  </button>
                  <ul class="dropdown-menu">
                    {%- for subChild in child.children %}
                      <li class="dropdown-item">
                        <a href="{{ subChild.url | url }}">{{ subChild.title }}</a>
                      </li>
                    {%- endfor %}
                  </ul>
                {% else %}
                  <a href="{{ child.url | url }}">{{ child.title }}</a>
                {% endif %}
              </li>
            {%- endfor %}
          </ul>
        {% else %}
          <a href="{{ entry.url | url }}">{{ entry.title }}</a>
        {% endif %}
      </li>
    {%- endfor %}
  </ul>
</nav>
</div>
{% if item.data.FontAwesomeIcon or FontAwesomeIcon %}
    <a href="{{ item.url | url }}">
        <span
            class="icon fa-{{ item.data.FontAwesomeIcon or FontAwesomeIcon }} text-2xl"
            aria-label="icon-representing-{{ item.data.title | slugify}}"
            title="Icon representing {{ item.data.title }}"
        ></span>
    </a>
{% endif %}
{% if collectionName == 'podcasts' %}
    <img
        data-pagefind-meta="image[src], image_alt[alt]"
        {% if cover or item.data.cover %}
            src="/assets/images/{{ cover or item.data.cover }}"
            alt="{{ item.data.coverAlt  or coverAlt }}"
            title="{{ item.data.coverAlt or coverAlt }}"
        {% endif %}
        {% if not cover and not item.data.cover %}
            src="/assets/images/content-content-cover-1024px.png"
            alt="Content Content podcast with Ed Marsh"
            title="Content Content podcast with Ed Marsh"
        {% endif %}
        class="w-full h-48 border-4 shadow-sm"/>
{% endif %}